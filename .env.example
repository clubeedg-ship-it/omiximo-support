# Database
DATABASE_URL=postgresql+asyncpg://omiximo:omiximo_dev@db:5432/omiximo_support

# Encryption — generate a new key with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=GENERATE_WITH_COMMAND_ABOVE

# LLM via OpenRouter (classification only — never generates responses)
LLM_API_KEY=your-openrouter-api-key
LLM_MODEL=anthropic/claude-sonnet-4
LLM_API_BASE_URL=https://openrouter.ai/api/v1

# Mirakl Connect — centralized OAuth2 API (preferred)
# Obtain credentials from https://connect-api.mirakl.net
MIRAKL_CONNECT_CLIENT_ID=your-connect-client-id
MIRAKL_CONNECT_CLIENT_SECRET=your-connect-client-secret
MIRAKL_CONNECT_SELLER_ID=your-seller-id

# Mirakl polling
MIRAKL_POLL_INTERVAL_SECONDS=300

# Frontend
VITE_API_URL=http://localhost:8000
